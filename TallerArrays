import java.util.Scanner;

public class TallerArrays {

    public static void main(String[] args) {
        //permite que el usuario pueda ingresar los datos
        Scanner scanner = new Scanner(System.in);

        // permite almacenar variables
        double[] datos = new double[8];

        // Pedir los valores al usuario usar solo comas ya que con puntos el codigo presenta error
        for (int i = 0; i < datos.length; i++) {
            System.out.print("Ingrese el valor " + (i + 1) + ": ");
            datos[i] = scanner.nextDouble();
        }

        // Mostrar resultados digitados en el scanner
        mostrarValores(datos);
        //presneta el dato de suma
        System.out.println("Suma: " + calcularSuma(datos));
        //presneta el dato de promedio
        System.out.println("Promedio: " + calcularPromedio(datos));
        //presneta el dato mayor
        System.out.println("Mayor: " + obtenerMayor(datos));
        //presneta el dato menor
        System.out.println("Menor: " + obtenerMenor(datos));

        scanner.close();
    }

    // Mostrar valores
    public static void mostrarValores(double[] datos) {
        System.out.println("Valores ingresados:");
        for (int i = 0; i < datos.length; i++) {
            System.out.println(datos[i]);
        }
    }

    // Calcular suma
    public static double calcularSuma(double[] datos) {
        double suma = 0;
        for (int i = 0; i < datos.length; i++) {
            suma += datos[i];
        }
        return suma;
    }

    // Calcular promedio
    public static double calcularPromedio(double[] datos) {
        return calcularSuma(datos) / datos.length;
    }

    // Obtener mayor
    public static double obtenerMayor(double[] datos) {
        double mayor = datos[0];
        for (int i = 1; i < datos.length; i++) {
            if (datos[i] > mayor) {
                mayor = datos[i];
            }
        }
        return mayor;
    }

    // Obtener menor
    public static double obtenerMenor(double[] datos) {
        double menor = datos[0];
        for (int i = 1; i < datos.length; i++) {
            if (datos[i] < menor) {
                menor = datos[i];
            }
        }
        return menor;
    }
}
